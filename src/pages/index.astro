---
import type { Resume, WorkExperience } from "../types";

const response = await fetch(import.meta.env.API_URL);
const data: Resume = await response.json();

const parseStartYear = (years: string): number => {
  const m = years.match(/(\d{4})/);
  return m ? parseInt(m[1], 10) : 0;
};

const parseEndYear = (years: string): number => {
  if (/Present/i.test(years)) return 9999;
  const all = years.match(/\d{4}/g) ?? [];
  return all.length ? parseInt(all[all.length - 1], 10) : 0;
};

const sortedExperiences: WorkExperience[] = [...data.workExperiences].sort(
  (a, b) =>
    parseEndYear(b.years) - parseEndYear(a.years) ||
    parseStartYear(b.years) - parseStartYear(a.years) ||
    b.id - a.id
);

const sortedEducations = [...data.educations].sort((a, b) => b.id - a.id);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={data.about} />
    <title>{data.name} - {data.title}</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
        font-size: 13px;
        line-height: 1.55;
        color: #111;
        background: #fff;
      }

      .page {
        max-width: 760px;
        margin: 0 auto;
        padding: 48px 40px;
      }

      /* Header */
      .header-name {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 4px;
      }

      .header-title {
        font-size: 13px;
        color: #444;
        margin-bottom: 3px;
      }

      .header-contact {
        font-size: 12px;
        color: #333;
      }

      .header-contact a {
        color: #333;
        text-decoration: none;
      }

      .header-contact a:hover {
        text-decoration: underline;
      }

      .sep { margin: 0 5px; color: #888; }

      /* Section */
      .section-title {
        font-size: 13px;
        font-weight: 700;
        border-bottom: 1.5px solid #111;
        padding-bottom: 2px;
        margin-top: 22px;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }

      /* Entry row (company/role + date) */
      .entry-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 12px;
      }

      .entry-left {
        font-weight: 600;
        font-size: 13px;
      }

      .entry-left .role {
        font-weight: 400;
      }

      .entry-date {
        font-size: 12px;
        color: #444;
        white-space: nowrap;
        flex-shrink: 0;
      }

      .entry-sub {
        font-size: 12px;
        color: #555;
        margin-top: 1px;
      }

      /* Bullets */
      ul.bullets {
        list-style-type: disc;
        margin-top: 5px;
        padding-left: 18px;
      }

      ul.bullets li {
        margin-bottom: 2px;
      }

      /* Entry spacing */
      .entry {
        margin-bottom: 14px;
      }

      /* Skills */
      .skill-row {
        margin-bottom: 3px;
      }

      .skill-label {
        font-weight: 600;
      }

      /* Project description */
      .project-desc {
        margin-top: 3px;
        color: #333;
      }

      .project-stack {
        margin-top: 2px;
        font-size: 12px;
        color: #555;
      }

      /* Footer */
      .footer {
        margin-top: 36px;
        font-size: 11px;
        color: #aaa;
        text-align: center;
      }

      @media print {
        body { font-size: 11px; }
        .page { padding: 24px 28px; max-width: 100%; }
        a { color: inherit; }
      }
    </style>
  </head>
  <body>
    <div class="page">

      <!-- Header -->
      <div>
        <div class="header-name">{data.name}</div>
        <div class="header-title">{data.title}{data.headline ? ` · ${data.headline}` : ''}</div>
        <div class="header-contact">
          <span>{data.address}</span>
          {data.links.map((link) => (
            <><span class="sep">|</span><a href={link.url} target="_blank" rel="noopener">{link.name}</a></>
          ))}
        </div>
      </div>

      <!-- Summary / Objectives -->
      <div class="section-title">Summary</div>
      <ul class="bullets">
        {data.objectives.map((item) => <li>{item}</li>)}
      </ul>

      <!-- Professional Experience -->
      <div class="section-title">Professional Experience</div>
      {sortedExperiences.map((item) => (
        <div class="entry">
          <div class="entry-header">
            <span class="entry-left">
              <strong>{item.companyName}</strong>
              <span class="role"> — {item.roles}</span>
            </span>
            <span class="entry-date">
              {item.location} · {item.years}{item.type ? ` · ${item.type}` : ''}
            </span>
          </div>
          <ul class="bullets">
            {item.jobDesc.map((desc) => <li>{desc}</li>)}
          </ul>
        </div>
      ))}

      <!-- Notable Projects -->
      {data.notableProjects && data.notableProjects.length > 0 && (
        <>
          <div class="section-title">Notable Projects</div>
          {data.notableProjects.map((item) => (
            <div class="entry">
              <div class="entry-header">
                <span class="entry-left">
                  {item.url
                    ? <strong><a href={item.url} target="_blank" rel="noopener" style="color:inherit;text-decoration:none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">{item.name}</a></strong>
                    : <strong>{item.name}</strong>
                  }
                  <span class="role"> — {item.role}</span>
                  <span style="color:#666;font-weight:400;"> · {item.category}</span>
                </span>
                <span class="entry-date">{item.year}</span>
              </div>
              <p class="project-desc">{item.description}</p>
              <p class="project-stack"><span class="skill-label">Stack:</span> {item.stack.join(', ')}</p>
            </div>
          ))}
        </>
      )}

      <!-- Skills -->
      <div class="section-title">Skills</div>
      {data.skills.map((item) => (
        <div class="skill-row">
          <span class="skill-label">{item.type}:</span> {item.tools.join(', ')}
        </div>
      ))}

      <!-- Additional Activities -->
      <div class="section-title">Additional Activities</div>
      {data.additionalActivities.map((item) => (
        <div class="entry">
          <div class="entry-left">{item.type}</div>
          <ul class="bullets">
            {item.activities.map((activity) => <li>{activity}</li>)}
          </ul>
        </div>
      ))}

      <!-- Languages -->
      {data.languages && data.languages.length > 0 && (
        <>
          <div class="section-title">Languages</div>
          <ul class="bullets">
            {data.languages.map((lang) => (
              <li><span class="skill-label">{lang.name}</span> — {lang.level}</li>
            ))}
          </ul>
        </>
      )}

      <!-- Education -->
      <div class="section-title">Education</div>
      {sortedEducations.map((item) => (
        <div class="entry">
          <div class="entry-header">
            <span class="entry-left">
              <strong>{item.schoolName}</strong>
              <span class="role"> — {item.title}</span>
            </span>
            <span class="entry-date">{item.location} · {item.years}</span>
          </div>
        </div>
      ))}

      {data.meta?.updatedAt && (
        <div class="footer">Last updated: {data.meta.updatedAt}</div>
      )}

    </div>
  </body>
</html>
